{
  "pluginId": "chromaspace",
  "displayName": "Chromaspace",
  "releaseRepo": "MoazElgabry/Chromaspace",
  "minManagerVersion": "0.1.0",
  "hostProcesses": [
    "Resolve",
    "DaVinci Resolve",
    "Fusion",
    "Fusion Studio",
    "Nuke",
    "NukeX",
    "NukeStudio",
    "Hiero"
  ],
  "requiredFamilies": [
    "windows",
    "macos",
    "linux"
  ],
  "availableStableMarker": "manager-available-stable",
  "versionPattern": "(?:^|-)v(?<version>.+)$",
  "assetRules": [
    {
      "family": "windows",
      "platform": "windows",
      "arch": "x86_64",
      "assetPattern": "^Chromaspace_.*windows.*portable\\.zip$",
      "packageType": "zip",
      "bundleName": "Chromaspace.ofx.bundle",
      "bundleIdentifier": "com.moazelgabry.Chromaspace",
      "installPath": "C:\\Program Files\\Common Files\\OFX\\Plugins"
    },
    {
      "family": "macos",
      "platform": "macos",
      "arch": "universal",
      "assetPattern": "^Chromaspace_.*macOS.*portable\\.zip$",
      "packageType": "zip",
      "bundleName": "Chromaspace.ofx.bundle",
      "bundleIdentifier": "com.moazelgabry.Chromaspace",
      "installPath": "/Library/OFX/Plugins"
    },
    {
      "family": "linux",
      "platform": "linux",
      "arch": "x86_64",
      "assetPattern": "^Chromaspace_.*linux.*portable\\.(?:tar\\.gz|zip)$",
      "packageType": "tar.gz",
      "bundleName": "Chromaspace.ofx.bundle",
      "bundleIdentifier": "com.moazelgabry.Chromaspace",
      "installPath": "/usr/OFX/Plugins"
    }
  ]
}
